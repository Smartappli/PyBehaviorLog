{
  "name": "pybehaviorlog",
  "profile": "dealhost-container",
  "runtime": "docker",
  "port_env": "PORT",
  "default_port": 8000,
  "healthcheck_path": "/health/",
  "release_metadata_path": "/release.json",
  "start_command": "granian --interface asgi --host 0.0.0.0 --port ${PORT:-8000} --workers ${GRANIAN_WORKERS:-2} --blocking-threads ${GRANIAN_BLOCKING_THREADS:-4} config.asgi:application",
  "required_environment": [
    "DJANGO_SECRET_KEY",
    "DJANGO_ALLOWED_HOSTS or DEALHOST_APP_URL",
    "DATABASE_URL",
    "PORT"
  ],
  "optional_environment": [
    "REDIS_URL",
    "PYBEHAVIORLOG_CACHE_BACKEND",
    "DEALHOST_SDK_MODULE"
  ]
}
