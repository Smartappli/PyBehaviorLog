DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-dealhost-secret

DEALHOST_ENABLED=1
DEALHOST_APP_URL=https://pybehaviorlog.example.com
DEALHOST_ALLOWED_HOSTS=pybehaviorlog.example.com
DEALHOST_CSRF_TRUSTED_ORIGINS=https://pybehaviorlog.example.com
DEALHOST_SDK_MODULE=dealhost_sdk

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/pybehaviorlog
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=6

# Use Redis when Dealhost provides it. Use locmem only for small single-instance deployments.
REDIS_URL=redis://HOST:6379/1
PYBEHAVIORLOG_CACHE_BACKEND=redis

PORT=8000
GRANIAN_WORKERS=2
GRANIAN_BLOCKING_THREADS=4
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=2592000
