DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=pybehaviorlog
POSTGRES_USER=pybehaviorlog
POSTGRES_PASSWORD=pybehaviorlog
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=12

REDIS_URL=redis://redis:6379/1
PYBEHAVIORLOG_CACHE_BACKEND=redis
CACHE_KEY_PREFIX=pybehaviorlog

SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=0

PORT=8000
GRANIAN_WORKERS=2
GRANIAN_BLOCKING_THREADS=4
